let a = 10;

let b = a;

b++;

console.log(a, b);

// Output:
// 10 11



// Q21

const person1 = {

    name: "SSS",

    child: {
        age: 5
    }

};

const person2 = person1;

person2.name = "AAA";

console.log(person1.name);

// Output:
// AAA


// Q22

const original = {

    x: 1,

    nested: {
        y: 2
    }

};

const shallowCopy = { ...original };

shallowCopy.x = 100;

shallowCopy.nested.y = 999;

console.log(original);

console.log(shallowCopy);



// Q23

const copyWithAssign = Object.assign({}, original);

copyWithAssign.nested.y = 500;

console.log(original);



// Q24

const deepSrc = {

    n: 1,

    d: new Date(),

    arr: [1, { k: 2 }],

    set: new Set([1, 2, 3])

};

const deepClone = structuredClone(deepSrc);

deepClone.arr[1].k = 999;

console.log(deepSrc.arr[1].k);

console.log(deepClone.arr[1].k);

// Original:
// 2

// Clone:
// 999



// Q25

const arr1 = [1, [2, 3]];

const arr3 = [...arr1];

arr1[1][0] = 99;

console.log(arr3[1][0]);

// Output:
// 99



const arr4 = structuredClone(arr1);

arr1[1][0] = 500;

console.log(arr4[1][0]);




// Q26

const m1 = new Map([
    ["k", { v: 1 }]
]);

const m2 = new Map(m1);

m2.get("k").v = 42;

console.log(m1.get("k").v);

// Output:
// 42


// Q27

const m3 = structuredClone(m1);

m3.get("k").v = 7;

console.log(m1.get("k").v);

console.log(m3.get("k").v);

// m1 = 42
// m3 = 7


// Q28

const productIds = [101, 102, 101, 103, 102, 104];

const uniqueIds = [...new Set(productIds)];

const products = new Map();

for (const id of uniqueIds) {

    products.set(id, "available");

}

console.log(products.size);

for (const [id, status] of products) {

    console.log(id, status);

}


// Q29

const courseName = "JavaScript";

const hours = 40;

const course = {

    courseName,

    hours,

    info() {

        console.log(`${this.courseName} - ${this.hours} hours`);

    },

    ["course_id"]: 100

};

for (const [key, value] of Object.entries(course)) {

    console.log(key, value);

}


// Q30

let personA = {

    name: "SSSSSSS",

    son: {
        age: 5
    }

};

console.log(Object.entries(personA));



let personB = personA;

personB.name = "Ahmed";



let personC = structuredClone(personA);

personC.son.age = 20;


console.log("personA:", personA);

console.log("personB:", personB);

console.log("personC:", personC);

