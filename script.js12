
// Q1
const fruits = ["apple", "banana", "cherry"];

console.log("for...in:");

for (const index in fruits) {
    console.log(index, "->", fruits[index]);
}

console.log("for...of:");

for (const fruit of fruits) {
    console.log(fruit);
}


// Q2


for (const [index, value] of fruits.entries()) {
    console.log(index, "->", value);
}


// Q3

const text = "NTI";

console.log("for...in:");

for (const index in text) {
    console.log(index, "->", text[index]);
}

console.log("for...of:");

for (const character of text) {
    console.log(character);
}

// for...in gets indexes.
// for...of gets values.


// Q4

const user = {
    name: "Ali",
    age: 25
};

for (const [key, value] of Object.entries(user)) {
    console.log(key, "->", value);
}


// Q5

for (const number of [1, 2, 3, 4, 5, 6]) {

    if (number === 3) {
        continue;
    }

    console.log(number);
}

// Output:
// 1
// 2
// 4
// 5
// 6




// Q6

const userMap = new Map();

userMap.set("name", "Ahmed");
userMap.set(100, "ID");

const objectKey = { id: 1 };

userMap.set(objectKey, "UserObject");

console.log(userMap);
console.log(typeof userMap);
console.log(userMap.size);


// Q7

console.log(userMap.get("name"));

console.log(userMap.has("age"));

userMap.set("age", 25);

userMap.delete(100);

console.log(userMap.size);


// Q8

console.log("All Entries:");

for (const [key, value] of userMap) {
    console.log(key, "->", value);
}

console.log("Keys:");

for (const key of userMap.keys()) {
    console.log(key);
}

console.log("Values:");

for (const value of userMap.values()) {
    console.log(value);
}


// Q9

// Reasons to use Map:

// 1. Keys can be any data type
// 2. Map keeps insertion order
// 3. Map has useful methods like set, get, has and delete


// Q10

userMap.clear();

console.log(userMap.size);

// Output:
// 0




// Q11

const numbersSet = new Set();

numbersSet.add(10);
numbersSet.add(21);
numbersSet.add(2);
numbersSet.add(3);
numbersSet.add(2);
numbersSet.add(10);

console.log(numbersSet);
console.log(numbersSet.size);

// Size is 4, not 6,


// Q12

console.log(numbersSet.has(2));

numbersSet.delete(3);

console.log(numbersSet.has(3));


// Q13

console.log("Set Values:");

for (const value of numbersSet.values()) {
    console.log(value);
}

console.log("Set Entries:");

for (const entry of numbersSet.entries()) {
    console.log(entry);
}

// In Set the key and the value are the same


// Q14

const nums = [1, 2, 2, 3, 4, 4, 5];

const uniqueNumbers = [...new Set(nums)];

console.log(uniqueNumbers);

// Output:
// [1, 2, 3, 4, 5]


// Q15

// Differences between Set and Array

// 1. Set does not allow duplicates
// 2. Array has indexes, but Set does not
// 3. Array uses push(), while Set uses add()





// Q16

const name = "Ahmed";
const age = 25;

// Old way

const oldObject = {
    name: name,
    age: age
};

// Shorthand way

const newObject = {
    name,
    age
};

console.log(oldObject);
console.log(newObject);


// Q17

const calculator = {

    add(a, b) {
        return a + b;
    },

    multiply(a, b) {
        return a * b;
    }

};

console.log(calculator.add(5, 3));

console.log(calculator.multiply(5, 3));


// Q18

const key1 = "email";
const key2 = "phone";

const contact = {

    [key1]: "test@gmail.com",

    [key2]: "0123456789",

    ["user_" + 99]: "special user"

};

console.log(contact);


// Q19

function buildPayload(type, value) {

    return {

        type,

        value,

        createdAt: new Date().toISOString(),

        print() {
            console.log(`${type}: ${value}`);
        },

        [type + "_flag"]: true

    };

}

const payload = buildPayload("order", 12345);

console.log(payload);

payload.print();





