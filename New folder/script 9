var persons = JSON.parse(localStorage.getItem("persons")) || [];
var currentIndex = -1;

displayData(persons);


function savePerson() {

    var person = {
        firstName: document.getElementById("firstName").value,
        lastName: document.getElementById("lastName").value,
        age: document.getElementById("age").value,
        gender: document.getElementById("gender").value,
        department: document.getElementById("department").value,
        isGraduated: document.getElementById("graduated").checked
    };

    if (currentIndex == -1) {

        persons.push(person);

    } else {

        persons[currentIndex] = person;
        currentIndex = -1;

        document.getElementById("saveBtn").innerHTML = "Add Person";
    }

    localStorage.setItem("persons", JSON.stringify(persons));

    displayData(persons);

    clearData();
}


function displayData(arr) {

    var cartona = "";

    for (var i = 0; i < arr.length; i++) {

        cartona += `
        <tr>
            <td>${arr[i].firstName} ${arr[i].lastName}</td>
            <td>${arr[i].age}</td>
            <td>${arr[i].gender}</td>
            <td>${arr[i].department}</td>
            <td>${arr[i].isGraduated ? "Graduate" : "Student"}</td>

            <td>
                <button onclick="editPerson(${i})">Edit</button>
                <button onclick="deletePerson(${i})">Delete</button>
            </td>
        </tr>
        `;
    }

    document.getElementById("tbody").innerHTML = cartona;
}


function deletePerson(index) {

    persons.splice(index, 1);

    localStorage.setItem("persons", JSON.stringify(persons));

    displayData(persons);
}


function editPerson(index) {

    currentIndex = index;

    document.getElementById("firstName").value = persons[index].firstName;
    document.getElementById("lastName").value = persons[index].lastName;
    document.getElementById("age").value = persons[index].age;
    document.getElementById("gender").value = persons[index].gender;
    document.getElementById("department").value = persons[index].department;
    document.getElementById("graduated").checked = persons[index].isGraduated;

    document.getElementById("saveBtn").innerHTML = "Update Person";
}


function clearData() {

    document.getElementById("firstName").value = "";
    document.getElementById("lastName").value = "";
    document.getElementById("age").value = "";
    document.getElementById("gender").value = "";
    document.getElementById("department").value = "";
    document.getElementById("graduated").checked = false;
}


function searchPerson(term) {

    var result = [];

    for (var i = 0; i < persons.length; i++) {

        if (
            persons[i].firstName.toLowerCase().includes(term.toLowerCase()) ||
            persons[i].lastName.toLowerCase().includes(term.toLowerCase()) ||
            persons[i].department.toLowerCase().includes(term.toLowerCase())
        ) {

            result.push(persons[i]);
        }
    }

    displayData(result);
}